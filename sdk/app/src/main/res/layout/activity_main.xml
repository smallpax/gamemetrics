<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        tools:context=".MainActivity">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:text="GameMetrics Sample"
                android:textSize="24sp"
                android:textStyle="bold" />

        <Button
                android:id="@+id/btnTrackEvent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Track Event" />

        <Button
                android:id="@+id/btnTrackScreen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Track Screen" />

        <Button
                android:id="@+id/btnSetUserId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Set User ID" />

        <Button
                android:id="@+id/btnLogException"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Log Exception" />

        <Button
                android:id="@+id/btnFlush"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Flush Now" />

        <Button
                android:id="@+id/btnForceCrash"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Force Crash" />

</LinearLayout>
