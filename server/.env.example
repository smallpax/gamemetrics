# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.

# ─── Portal auth (REQUIRED) ───────────────────────────────────────────────
# Session-signing secret. The server refuses to start without it.
# Generate one with:  openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of the portal (optional; defaults to http://localhost:3000)
# BETTER_AUTH_URL=http://localhost:3000

# ─── Database (optional — these are the local docker-compose defaults) ─────
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=gamemetrics
# DB_PASSWORD=gamemetrics
# DB_NAME=gamemetrics

# ─── Demo seed (optional — used by `npm run seed:auth`) ────────────────────
# DEMO_EMAIL=demo@gamemetrics.dev
# DEMO_PASSWORD=change-me

# ─── Rate limiting (optional — sensible defaults in code) ──────────────────
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000
# LOGIN_RATE_LIMIT_MAX=5
# LOGIN_RATE_LIMIT_WINDOW_MS=60000
